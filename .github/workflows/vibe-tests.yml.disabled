# DISABLED: This workflow is temporarily disabled.
#
# To re-enable:
# 1. Add ANTHROPIC_API_KEY secret to the repository
# 2. Rename this file back to vibe-tests.yml
# =============================================================================

name: Vibe Tests

on:
  pull_request:
    branches: [main, master]
  push:
    branches: [main, master]
  workflow_dispatch:
    inputs:
      sample_size:
        description: 'Number of test prompts to run'
        required: false
        default: '10'

concurrency:
  group: vibe-tests-${{ github.head_ref || github.ref }}
  cancel-in-progress: true

jobs:
  vibe-test:
    name: Run Vibe Tests
    runs-on: ubuntu-latest
    permissions:
      contents: read
      pull-requests: write
      actions: read

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '22'
          cache: 'yarn'

      - name: Install dependencies
        run: yarn install --frozen-lockfile

      - name: Run vibe tests
        id: vibe-test
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          SKILL_DOC: packages/core/xds.md
        run: |
          # Determine sample size
          SAMPLE_SIZE="${{ github.event.inputs.sample_size || '10' }}"

          # Run the tests
          echo "Running vibe tests with sample size: $SAMPLE_SIZE"
          yarn workspace @xds/vibe-tests test:xds:sample 2>&1 | tee vibe-test-output.txt

          # Extract iteration ID from output
          ITERATION_ID=$(grep -oP 'Iteration: \K[a-f0-9]+' vibe-test-output.txt | head -1)
          echo "iteration_id=$ITERATION_ID" >> $GITHUB_OUTPUT
          echo "Iteration ID: $ITERATION_ID"

      - name: Aggregate results
        id: aggregate
        if: steps.vibe-test.outputs.iteration_id != ''
        run: |
          ITERATION_ID="${{ steps.vibe-test.outputs.iteration_id }}"
          yarn workspace @xds/vibe-tests aggregate --iteration "$ITERATION_ID" --ci

      - name: Upload results artifact
        if: steps.vibe-test.outputs.iteration_id != ''
        uses: actions/upload-artifact@v4
        with:
          name: vibe-test-results-${{ steps.vibe-test.outputs.iteration_id }}
          path: |
            internal/vibe-tests/results/${{ steps.vibe-test.outputs.iteration_id }}/
          retention-days: 90

      - name: Upload HTML report
        if: steps.vibe-test.outputs.iteration_id != ''
        uses: actions/upload-artifact@v4
        with:
          name: vibe-test-report-${{ steps.vibe-test.outputs.iteration_id }}
          path: internal/vibe-tests/results/${{ steps.vibe-test.outputs.iteration_id }}/report.html
          retention-days: 90

      - name: Comment on PR
        if: github.event_name == 'pull_request' && steps.vibe-test.outputs.iteration_id != ''
        uses: actions/github-script@v7
        with:
          script: |
            const successRate = '${{ steps.aggregate.outputs.success_rate }}';
            const gold = '${{ steps.aggregate.outputs.gold }}' || '0';
            const green = '${{ steps.aggregate.outputs.green }}' || '0';
            const yellow = '${{ steps.aggregate.outputs.yellow }}' || '0';
            const red = '${{ steps.aggregate.outputs.red }}' || '0';
            const iterationId = '${{ steps.vibe-test.outputs.iteration_id }}';
            const runUrl = `${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId}`;

            // Determine status emoji
            let statusEmoji = '🔴';
            if (parseInt(successRate) >= 90) statusEmoji = '🟢';
            else if (parseInt(successRate) >= 70) statusEmoji = '🟡';

            const body = `## ${statusEmoji} Vibe Test Results

            **Iteration:** \`${iterationId}\`
            **Success Rate:** ${successRate}%

            ### Quality Tiers
            | Tier | Count |
            |------|-------|
            | 🥇 Gold (pure XDS) | ${gold} |
            | 🟢 Green (acceptable) | ${green} |
            | 🟡 Yellow (anti-pattern) | ${yellow} |
            | 🔴 Red (critical) | ${red} |

            <details>
            <summary>Tier Definitions</summary>

            - **Gold**: Pure XDS, no escape hatches needed
            - **Green**: Correct components with acceptable escape hatches
            - **Yellow**: Anti-patterns that break theming (hardcoded values, inline styles)
            - **Red**: Critical failures (hallucinations, wrong components)
            </details>

            📊 [View full report](${runUrl}) (download artifacts)
            `;

            // Find existing comment
            const { data: comments } = await github.rest.issues.listComments({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
            });

            const botComment = comments.find(comment =>
              comment.user.type === 'Bot' &&
              comment.body.includes('Vibe Test Results')
            );

            if (botComment) {
              await github.rest.issues.updateComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                comment_id: botComment.id,
                body: body
              });
            } else {
              await github.rest.issues.createComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: context.issue.number,
                body: body
              });
            }

      - name: Check threshold
        if: steps.aggregate.outputs.success_rate != ''
        run: |
          SUCCESS_RATE="${{ steps.aggregate.outputs.success_rate }}"
          RED="${{ steps.aggregate.outputs.red }}"

          echo "✅ Success rate: $SUCCESS_RATE%"
          echo "✅ Critical failures: $RED"

          # Fail if success rate is below 70%
          if [ "$SUCCESS_RATE" -lt 70 ]; then
            echo "::error::Vibe test success rate ($SUCCESS_RATE%) is below threshold (70%)"
            exit 1
          fi

          echo "✅ Vibe tests passed with $SUCCESS_RATE% success rate"

  store-results:
    name: Store Historical Results
    needs: vibe-test
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: vibe-test-history
          fetch-depth: 0

      - name: Download artifacts
        uses: actions/download-artifact@v4
        with:
          pattern: vibe-test-results-*
          path: results/
          merge-multiple: true

      - name: Commit results
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"

          # Create branch if it doesn't exist
          if ! git rev-parse --verify vibe-test-history >/dev/null 2>&1; then
            git checkout --orphan vibe-test-history
            git rm -rf . || true
            echo "# Vibe Test Results History" > README.md
            echo "" >> README.md
            echo "This branch stores historical vibe test results from CI runs." >> README.md
          fi

          # Add new results
          TIMESTAMP=$(date +%Y-%m-%d-%H%M%S)
          COMMIT_SHA="${{ github.sha }}"
          mkdir -p "history/${TIMESTAMP}-${COMMIT_SHA:0:7}"
          cp -r results/* "history/${TIMESTAMP}-${COMMIT_SHA:0:7}/" || true

          # Commit and push
          git add .
          git commit -m "Add vibe test results from ${COMMIT_SHA:0:7}" || echo "No changes to commit"
          git push origin vibe-test-history || echo "Failed to push, branch may not exist"
