{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@astryxdesign/core": [
        "../../packages/core/src"
      ],
      "@astryxdesign/core/*": [
        "../../packages/core/src/*"
      ],
      "@astryxdesign/theme/neutral": [
        "../../packages/themes/neutral/src/source.ts"
      ],
      "@stylexjs/stylex": [
        "../../node_modules/@stylexjs/stylex"
      ],
      "@astryxdesign/astryx-rhf": [
        "../../packages/astryx-rhf/src"
      ],
      "react-hook-form": [
        "../../node_modules/react-hook-form"
      ],
      "@hookform/resolvers/*": [
        "../../node_modules/@hookform/resolvers/*"
      ],
      "zod": [
        "../../packages/astryx-rhf/node_modules/zod"
      ],
      "zod/*": [
        "../../packages/astryx-rhf/node_modules/zod/*"
      ]
    }
  },
  "include": [
    "**/*.tsx"
  ]
}
