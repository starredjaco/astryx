{
  "name": "@xds/theme-default",
  "version": "0.0.6",
  "private": false,
  "description": "Default theme for XDS components (Heroicons)",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "xds theme build src/defaultTheme.ts -o dist/theme.css && tsup && rm -f dist/default.js dist/default.d.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0"
  },
  "peerDependencies": {
    "@xds/core": "*",
    "react": ">=19"
  },
  "devDependencies": {
    "@xds/cli": "*"
  },
  "module": "./dist/index.mjs"
}
