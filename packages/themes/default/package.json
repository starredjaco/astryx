{
  "name": "@xds/theme-default",
  "version": "0.0.12",
  "private": false,
  "description": "Default theme for XDS — clean neutrals with Heroicons icon set",
  "author": "Meta Open Source",
  "license": "MIT",
  "homepage": "https://github.com/facebookexperimental/xds#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebookexperimental/xds.git",
    "directory": "packages/themes/default"
  },
  "bugs": {
    "url": "https://github.com/facebookexperimental/xds/issues"
  },
  "keywords": [
    "xds",
    "theme",
    "design-system",
    "heroicons",
    "design-tokens"
  ],
  "sideEffects": false,
  "main": "./dist/source.js",
  "types": "./dist/source.d.ts",
  "exports": {
    ".": {
      "types": "./dist/source.d.ts",
      "import": "./dist/source.mjs",
      "require": "./dist/source.js"
    },
    "./built": {
      "types": "./dist/default.d.ts",
      "import": "./dist/default.js",
      "require": "./dist/default.js"
    },
    "./theme.css": {
      "types": "./theme.css.d.ts",
      "default": "./dist/theme.css"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "xds theme build src/defaultTheme.ts -o dist/theme.css && tsup && tsc --project tsconfig.build.json"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0"
  },
  "peerDependencies": {
    "@xds/core": "*",
    "react": ">=19"
  },
  "devDependencies": {
    "@xds/cli": "*"
  },
  "module": "./dist/source.mjs"
}
