{
  "name": "@xds/theme-brutalist",
  "version": "0.0.14",
  "private": true,
  "description": "Brutalist theme for XDS — zero radius, monospace, heavy borders",
  "author": "Meta Open Source",
  "license": "MIT",
  "homepage": "https://github.com/facebookexperimental/xds#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebookexperimental/xds.git",
    "directory": "packages/themes/brutalist"
  },
  "bugs": {
    "url": "https://github.com/facebookexperimental/xds/issues"
  },
  "keywords": [
    "xds",
    "theme",
    "brutalist",
    "design-system",
    "design-tokens"
  ],
  "sideEffects": false,
  "main": "./dist/source.js",
  "module": "./dist/source.mjs",
  "types": "./dist/source.d.ts",
  "exports": {
    ".": {
      "types": "./dist/source.d.ts",
      "import": "./dist/source.mjs",
      "require": "./dist/source.js"
    },
    "./built": {
      "types": "./dist/brutalist.d.ts",
      "import": "./dist/brutalist.js",
      "require": "./dist/brutalist.js"
    },
    "./theme.css": {
      "types": "./theme.css.d.ts",
      "default": "./dist/theme.css"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "xds theme build src/brutalistTheme.ts -o dist/theme.css && tsup && tsc --project tsconfig.build.json"
  },
  "peerDependencies": {
    "@xds/core": "0.0.14"
  },
  "devDependencies": {
    "@xds/cli": "0.0.14"
  }
}
