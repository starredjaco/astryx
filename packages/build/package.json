{
  "name": "@xds/build",
  "version": "0.0.14",
  "description": "Build plugins for XDS source builds — babel, PostCSS, and Vite integrations",
  "author": "Meta Open Source",
  "license": "MIT",
  "homepage": "https://github.com/facebookexperimental/xds#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facebookexperimental/xds.git",
    "directory": "packages/build"
  },
  "bugs": {
    "url": "https://github.com/facebookexperimental/xds/issues"
  },
  "keywords": [
    "xds",
    "postcss",
    "stylex",
    "css-layers",
    "design-system"
  ],
  "main": "./src/config.js",
  "exports": {
    ".": "./src/config.js",
    "./babel": "./src/babel.js",
    "./postcss": "./src/index.js",
    "./vite": "./dist/vite.mjs",
    "./next": "./src/next.js"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "@stylexjs/babel-plugin": ">=0.18.0",
    "@babel/core": ">=7.0.0",
    "@stylexjs/unplugin": ">=0.18.0",
    "vite": ">=5.0.0"
  },
  "dependencies": {
    "fast-glob": "^3.3.0",
    "glob-parent": "^6.0.0",
    "is-glob": "^4.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  },
  "peerDependenciesMeta": {
    "@stylexjs/unplugin": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
