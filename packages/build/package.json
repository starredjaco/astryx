{
  "name": "@xds/build",
  "version": "0.0.1",
  "description": "Build plugins for XDS source builds — babel, PostCSS, and Vite integrations",
  "license": "MIT",
  "main": "./src/config.js",
  "exports": {
    ".": "./src/config.js",
    "./babel": "./src/babel.js",
