    "@stylexjs/postcss-plugin": "^0.19.0",
    "@types/lz-string": "^1.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "typescript": "^6.0.3",
